#include <stdio.h>
struct Date {
    int day, month, year;
};
struct Student {
    int id;
    struct Date dob;
};
int main() {
    struct Student s;
    s.id = 102;
    s.dob.day = 29;
    s.dob.month = 11;
    s.dob.year = 2007;
    printf("ID = %d\n", s.id);
    printf("DOB = %d-%d-%d\n", s.dob.day, s.dob.month, s.dob.year);
    printf("25331A05H9");
    return 0;
}
