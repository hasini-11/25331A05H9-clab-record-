#include <stdio.h>
int main() {
    int i;
    printf("Using continue:\n");
    for(i = 1; i <= 10; i++) {
        if(i == 5)
            continue;   // skip 5
        printf("%d ", i);
    }
    printf("\n\nUsing break:\n");
    for(i = 1; i <= 10; i++) {
        if(i == 5)
            break;      // stop loop
        printf("%d ", i);
    }
    return 0;
}
